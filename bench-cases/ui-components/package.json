{
  "name": "ui-libraries",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "bench:rspack": "NODE_ENV=production rspack build --config rspack.config.js",
    "bench:rspack:persistent": "BENCH_PERSISTENT_CACHE=1 NODE_ENV=production rspack build --config rspack.config.js",
    "bench:rspack:watch": "NODE_ENV=development rspack serve --config rspack.config.js --host 127.0.0.1",
    "bench:rspack:watch:persistent": "BENCH_PERSISTENT_CACHE=1 NODE_ENV=development rspack serve --config rspack.config.js --host 127.0.0.1",
    "bench:webpack": "NODE_ENV=production webpack --config webpack.config.js",
    "bench:webpack:persistent": "BENCH_PERSISTENT_CACHE=1 NODE_ENV=production webpack --config webpack.config.js",
    "bench:webpack:watch": "NODE_ENV=development webpack serve --config webpack.config.js --host 127.0.0.1",
    "bench:webpack:watch:persistent": "BENCH_PERSISTENT_CACHE=1 NODE_ENV=development webpack serve --config webpack.config.js --host 127.0.0.1",
    "bench:utoo": "NODE_ENV=production up build",
    "bench:utoo:persistent": "BENCH_PERSISTENT_CACHE=1 NODE_ENV=production up build",
    "bench:utoo:dev": "NODE_ENV=development up dev",
    "bench:utoo:dev:persistent": "BENCH_PERSISTENT_CACHE=1 NODE_ENV=development up dev",
    "bench:next": "node ../../scripts/prepare-next-case.mjs --import-mode=static && NODE_ENV=production next build .bench-next/project --turbopack --experimental-build-mode=compile",
    "bench:next:persistent": "BENCH_PERSISTENT_CACHE=1 node ../../scripts/prepare-next-case.mjs --import-mode=static && BENCH_PERSISTENT_CACHE=1 NODE_ENV=production next build .bench-next/project --turbopack --experimental-build-mode=compile",
    "bench:next:dev": "node ../../scripts/prepare-next-case.mjs --import-mode=static && NODE_ENV=development next dev .bench-next/project --turbopack",
    "bench:next:dev:persistent": "BENCH_PERSISTENT_CACHE=1 node ../../scripts/prepare-next-case.mjs --import-mode=static && BENCH_PERSISTENT_CACHE=1 NODE_ENV=development next dev .bench-next/project --turbopack"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.66.15",
    "@chakra-ui/react": "^3.36.0",
    "@coreui/react": "^5.12.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fluentui/react": "^8.125.6",
    "@headlessui/react": "^2.2.10",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mui/material": "^9.1.2",
    "@radix-ui/themes": "^3.3.0",
    "antd": "^6.5.0",
    "antd-mobile": "^5.42.3",
    "ant-design-vue": "^4.2.6",
    "element-plus": "^2.14.2",
    "naive-ui": "^2.44.1",
    "primevue": "^4.5.5",
    "primereact": "^10.9.8",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "rsuite": "^6.2.1",
    "react-dom": "^19.2.7",
    "styled-components": "^6.4.3",
    "vant": "^4.10.0",
    "vue": "^3.5.39",
    "vuetify": "^4.1.2"
  },
  "browserslist": "Chrome >= 93"
}
